<!DOCTYPE html>
<html lang="pt-br">
<head>

<meta charset="UTF-8">
<title>Catálogo de Filmes</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<!-- Fonte estilo Netflix -->
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">

<style>

body{
    background-color:#0b0b0b;
    color:white;
    font-family: 'Montserrat', sans-serif;
}

/* NAVBAR */
.navbar{
    background: linear-gradient(90deg,#000,#1a0000,#000);
    border-bottom:3px solid #e50914;
}

/* LOGO estilo Netflix */
.logo{
    font-family:'Bebas Neue', sans-serif;
    font-size:32px;
    letter-spacing:2px;
    color:#e50914 !important;
}

/* links menu */
.nav-link{
    color:white !important;
    font-weight:500;
    margin-left:15px;
    transition:0.3s;
}

.nav-link:hover{
    color:#e50914 !important;
}

/* container principal */
.main-container{
    background-color:#141414;
    padding:35px;
    border-radius:12px;
    box-shadow:0 0 25px rgba(229,9,20,0.2);
}

/* títulos */
h1,h2,h3{
    color:#e50914;
    font-family:'Bebas Neue', sans-serif;
    letter-spacing:1px;
}

/* tabela estilo streaming */
.table{
    color:white;
    background-color:#181818;
    border-radius:10px;
    overflow:hidden;
}

.table thead{
    background-color:#e50914;
    color:white;
}

.table tbody tr{
    border-color:#2a2a2a;
}

.table-hover tbody tr:hover{
    background-color:#2a0000;
}

/* badges */
.badge{
    background-color:#e50914;
}

.btn-cinema{
    background-color:#e50914;
    color:white;
    border:none;
    font-weight:600;
}

.btn-cinema:hover{
    background-color:#b20710;
    color:white;
}   

</style>

</head>

<body>

<nav class="navbar navbar-expand-lg">
<div class="container">

<a class="navbar-brand logo" href="/filmes">
CHINESFLIX
</a>

<div>

<a class="nav-link d-inline" href="/filmes">
Filmes
</a>

<a class="nav-link d-inline" href="/cadastro">
Cadastrar Filme
</a>

</div>

</div>
</nav>

<div class="container mt-5">

<div class="main-container">

{{{body}}}

</div>

</div>

</body>
</html>